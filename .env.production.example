# .env.production.example — copy to .env on the server and fill in.

# Database — Supabase (Project Settings → Database → "ORM"/Prisma).
# Use the IPv4 "pooler" host (not the IPv6-only direct connection).
# DATABASE_URL = app runtime (pooler); DIRECT_URL = migrations.
DATABASE_URL=
DIRECT_URL=

# Storage — Supabase (Project Settings → API). service_role is server-only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=pagistry-bucket

# Public domain (no scheme). www is added automatically by the Caddyfile.
APP_DOMAIN=example.com
APP_URL=https://example.com

# Auth / signing secrets — generate with: openssl rand -hex 32
AUTH_SECRET=
THUMBNAIL_SECRET=
METRICS_TOKEN=

# Email (Resend) — from address must be on your verified domain.
RESEND_API_KEY=
EMAIL_FROM="Pagistry <no-reply@example.com>"

# AI (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# OAuth (optional; callbacks use APP_URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
